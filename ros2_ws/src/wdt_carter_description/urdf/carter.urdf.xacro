<?xml version="1.0"?>
<!--
  Nova Carter URDF for Nav2 footprint + TF chain.

  Isaac Sim's Nova Carter USD publishes /tf with `odom → base_link`,
  so this URDF makes `base_link` the root and chains the static
  per-sensor frames off it:

    odom (from sim) → base_link → laser_frame

  The chassis collision/visual is approximated as a 0.6 × 0.4 × 0.5 m
  box. The actual Carter geometry is more complex; Nav2's costmap only
  needs an inflation-radius-friendly footprint, so the box is sufficient.

  Note: Phase 1 had a `base_footprint` root with `base_footprint →
  base_link` fixed joint, intended to follow the typical Nav2 mobile
  convention. But Isaac Sim publishes the dynamic transform with
  `child_frame_id: base_link`, not `base_footprint`, breaking the TF
  chain (M1 smoke debug 2026-05-15). Drop base_footprint and use
  base_link as both the URDF root and AMCL's `base_frame_id`.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="nova_carter">
  <xacro:arg name="robot_namespace" default=""/>

  <link name="base_link">
    <visual>
      <geometry><box size="0.6 0.4 0.5"/></geometry>
      <origin xyz="0 0 0.25"/>
    </visual>
    <collision>
      <geometry><box size="0.6 0.4 0.5"/></geometry>
      <origin xyz="0 0 0.25"/>
    </collision>
  </link>

  <link name="laser_frame"/>
  <joint name="base_link_to_laser" type="fixed">
    <parent link="base_link"/>
    <child link="laser_frame"/>
    <origin xyz="0 0 0.55"/>
  </joint>
</robot>
